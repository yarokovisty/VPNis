<?xml version="1.0" encoding="utf-8"?>
<!--
    String resources for the :data:vpn module.

    These are the only strings owned by this library module. They are intentionally minimal
    to avoid polluting the merged resource namespace. Localised variants belong alongside
    the :app module's per-locale values folders (issue out of scope here).
-->
<resources>
    <!-- Notification channel name shown in the system Settings → App notifications UI. -->
    <string name="vpn_notification_channel_name" translatable="true">VPN Tunnel</string>

    <!-- Notification channel description shown in Settings → App notifications → VPN Tunnel. -->
    <string name="vpn_notification_channel_description" translatable="true">Shows while the VPN tunnel is active</string>

    <!-- Label for the Disconnect action button inside the tunnel notification. -->
    <string name="vpn_notification_action_disconnect" translatable="true">Disconnect</string>

    <!-- Tunnel notification title (shown for every connection state). -->
    <string name="vpn_notification_title" translatable="true">VPNis</string>

    <!-- Tunnel notification body: no live tunnel / initial foreground post. -->
    <string name="vpn_notification_text_active" translatable="true">Tunnel active</string>

    <!-- Tunnel notification body while connecting. %1$s = server name. -->
    <string name="vpn_notification_text_connecting" translatable="true">Connecting to %1$s…</string>

    <!-- Tunnel notification body while connected. %1$s = server name (issue #128 adds a session timer). -->
    <string name="vpn_notification_text_connected" translatable="true">Connected · %1$s</string>

    <!-- Connected body with live traffic (issues #69/#130). %1$s = server, %2$s = download rate,
         %3$s = upload rate (each already "value unit", e.g. "1.2 MB/s"). ↓/↑ mark down/up. -->
    <string name="vpn_notification_text_connected_traffic" translatable="true">%1$s · ↓ %2$s · ↑ %3$s</string>

    <!-- Bitrate unit suffixes for the notification traffic line — mirror :feature:home units so the
         notification and the Home tiles read identically (issues #69/#130). -->
    <string name="vpn_traffic_unit_bps" translatable="true">B/s</string>
    <string name="vpn_traffic_unit_kbps" translatable="true">KB/s</string>
    <string name="vpn_traffic_unit_mbps" translatable="true">MB/s</string>

    <!-- ===== Error alert (issue #129): separate dismissible heads-up on the vpnis_alerts channel ===== -->

    <!-- Alert notification channel name (Settings → App notifications → VPN alerts). -->
    <string name="vpn_alert_channel_name" translatable="true">VPN alerts</string>

    <!-- Alert notification channel description. -->
    <string name="vpn_alert_channel_description" translatable="true">Warns when the VPN connection drops unexpectedly</string>

    <!-- Alert title. Names the event AND that it is involuntary (not a routine user disconnect). -->
    <string name="vpn_alert_title" translatable="true">VPN connection lost</string>

    <!-- Alert body: server could not be reached. -->
    <string name="vpn_alert_text_server_unreachable" translatable="true">Server unreachable. Tap to open VPNis.</string>

    <!-- Alert body: the active tunnel was interrupted (the real mid-session-drop copy users see). -->
    <string name="vpn_alert_text_tunnel_failed" translatable="true">The connection dropped. Tap to open VPNis.</string>

    <!-- Alert body: generic fallback (Unknown/other reasons; raw error detail is never shown here). -->
    <string name="vpn_alert_text_generic" translatable="true">Tap to open VPNis.</string>
</resources>
