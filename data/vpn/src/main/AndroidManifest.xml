<?xml version="1.0" encoding="utf-8"?>
<!--
    Manifest for the :data:vpn library module (issue #65).

    The <service> and permissions live here — in the module that DEFINES VpnTunnelService —
    rather than in :app, so the tunnel is self-contained. They merge into the application
    manifest once :app depends on :data:vpn (the fakeVpnModule -> vpnModule swap, issue #66).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Tunnel + Xray outbound traffic. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- registerNetworkCallback() in UnderlyingNetworkMonitor (underlying-network tracking). -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Foreground service that hosts the tunnel (issue #62). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        specialUse FGS type (issue #106). systemExempted was wrong: on API 34+ it additionally
        requires one of SCHEDULE_EXACT_ALARM / USE_EXACT_ALARM / the android:activate_vpn appop
        (granted only AFTER establish()), so startForeground() threw SecurityException before the
        tunnel ever came up. specialUse is grantable to a VPN app without that coupling and is the
        type VPN clients of the SaeedDev94/Xray family (ADR-0001) ship for their ongoing notification.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- API 33+: post the ongoing tunnel notification. The runtime grant is requested at the
         app/Activity layer; declaring it here lets the notification display once granted. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application>
        <!--
            VpnTunnelService (issues #61/#62/#63).
            - android:permission="BIND_VPN_SERVICE" + the android.net.VpnService intent action
              are what the OS VPN framework requires to bind a VpnService.
            - android:foregroundServiceType="specialUse" matches the
              ServiceCompat.startForeground(..., FOREGROUND_SERVICE_TYPE_SPECIAL_USE) call (issue #106).
            - android:exported="false" — only this app may start it.
        -->
        <service
            android:name="org.yarokovisty.vpnis.data.vpn.VpnTunnelService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <!--
                PROPERTY_SPECIAL_USE_FGS_SUBTYPE is a free-form justification string the Play review
                team inspects manually; it must match the future Play declaration form. For the
                self-distributed fallback channel it is still declared correctly.
            -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="This VPN app runs a foreground service to keep the encrypted tunnel that carries user traffic active while the app is backgrounded." />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>
</manifest>
