root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# ktlint reads its style from here. kotlin.code.style=official -> ktlint official ruleset.
ktlint_code_style = intellij_idea
max_line_length = 120
ktlint_standard_no-wildcard-imports = enabled
# Trailing commas follow the official IntelliJ Kotlin style.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true
# Compose @Composable functions are PascalCase — relax the function-naming rule for them.
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
